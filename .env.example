ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===================================
# ETF universe and mappings
# ===================================
ETF_LIST=CN:159659,US:QQQ,HK:02800
INDEX_PROXY_MAP={"NDX":["US:QQQ","CN:159659"],"SPX":["US:SPY","CN:513500"],"HSI":["HK:02800","CN:159920"]}
INDUSTRY_MAP={}
MARKETS_ENABLED=cn,hk,us
DATABASE_URL=sqlite:///./data/daily_etf_analysis.db
# set DISABLE_SCHEMA_GUARD=1 only for local test fixtures
DISABLE_SCHEMA_GUARD=

# ===================================
# Market data provider priority
# ===================================
REALTIME_SOURCE_PRIORITY=efinance,akshare,tushare,pytdx,baostock,yfinance
TUSHARE_TOKEN=
PYTDX_HOST=119.147.212.81
PYTDX_PORT=7709

# Provider resilience
PROVIDER_MAX_RETRIES=1
PROVIDER_BACKOFF_MS=200
PROVIDER_CIRCUIT_FAIL_THRESHOLD=3
PROVIDER_CIRCUIT_RESET_SECONDS=60

# ===================================
# LLM configuration (recommended: channel mode)
# Priority: LITELLM_CONFIG > LLM_CHANNELS > legacy keys
# ===================================
LITELLM_MODEL=
LITELLM_FALLBACK_MODELS=
LITELLM_CONFIG=

# Channel mode example
# LLM_CHANNELS=aihubmix,gemini
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxxx
# LLM_AIHUBMIX_MODELS=gpt-4o-mini,claude-3-5-sonnet
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini/gemini-2.5-flash
LLM_CHANNELS=

# Legacy keys (used only when no channels/YAML configured)
GEMINI_API_KEY=
GEMINI_API_KEYS=
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEYS=
OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_API_KEYS=

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ===================================
# News (V1 default: Tavily)
# ===================================
TAVILY_API_KEYS=
NEWS_MAX_AGE_DAYS=3
NEWS_PROVIDER_PRIORITY=tavily

# ===================================
# Scheduler (cron-like: sec min hour day month weekday)
# ===================================
SCHEDULE_ENABLED=false
SCHEDULE_CRON_CN=0 30 15 * * 1-5
SCHEDULE_CRON_HK=0 10 16 * * 1-5
SCHEDULE_CRON_US=0 10 22 * * 1-5

# ===================================
# Notification (Phase 3: multi-channel)
# ===================================
NOTIFY_CHANNELS=feishu
FEISHU_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=25
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
REPORT_TEMPLATES_DIR=templates
REPORT_RENDERER_ENABLED=false
REPORT_INTEGRITY_ENABLED=true
REPORT_HISTORY_COMPARE_N=0
MARKDOWN_TO_IMAGE_CHANNELS=
MARKDOWN_TO_IMAGE_MAX_CHARS=15000
MD2IMG_ENGINE=imgkit
METRICS_ENABLED=true

# ===================================
# Task reliability and lifecycle (Phase 4)
# ===================================
TASK_MAX_CONCURRENCY=2
# compatibility no-op (Phase 4 alignment keeps the key but does not enforce it)
TASK_QUEUE_MAX_SIZE=50
TASK_TIMEOUT_SECONDS=120
# compatibility no-op (active-task dedup is now always used)
TASK_DEDUP_WINDOW_SECONDS=300
RETENTION_TASK_DAYS=30
RETENTION_REPORT_DAYS=60
RETENTION_QUOTE_DAYS=14
INDUSTRY_TREND_WINDOW_DAYS=5
INDUSTRY_RISK_TOP_N=3
INDUSTRY_RECOMMEND_WEIGHTS={"buy":1,"hold":0,"sell":-1,"score_weight":0.5}

# ===================================
# API auth (Phase 3)
# ===================================
API_AUTH_ENABLED=false
API_ADMIN_TOKEN=
