# 运行环境（development/production 等）
ENVIRONMENT=development
# 日志级别（DEBUG/INFO/WARN/ERROR）
LOG_LEVEL=INFO
# 日志文件路径
LOG_FILE=logs/app.log

# ===================================
# ETF universe and mappings
# ===================================
# ETF 列表（按市场前缀，逗号分隔）
ETF_LIST=CN:159659,US:QQQ,HK:02800
# 指数到 ETF 代理映射（JSON）
INDEX_PROXY_MAP={"NDX":["US:QQQ","CN:159659"],"SPX":["US:SPY","CN:513500"],"HSI":["HK:02800","CN:159920"]}
# 行业映射（JSON）
INDUSTRY_MAP={}
# 启用市场列表（逗号分隔）
MARKETS_ENABLED=cn,hk,us
# 数据库连接字符串
DATABASE_URL=sqlite:///./data/daily_etf_analysis.db
# Schema Guard 开关（仅本地测试用，1=禁用）
DISABLE_SCHEMA_GUARD=

# ===================================
# Market data provider priority
# ===================================
# 实时数据源优先级（逗号分隔）
REALTIME_SOURCE_PRIORITY=efinance,akshare,tushare,pytdx,baostock,yfinance
# Tushare Token
TUSHARE_TOKEN=
# PyTDX 主机
PYTDX_HOST=119.147.212.81
# PyTDX 端口
PYTDX_PORT=7709

# Provider resilience
# 提供方最大重试次数
PROVIDER_MAX_RETRIES=1
# 退避时间（毫秒）
PROVIDER_BACKOFF_MS=200
# 熔断失败阈值（连续失败次数）
PROVIDER_CIRCUIT_FAIL_THRESHOLD=3
# 熔断重置时间（秒）
PROVIDER_CIRCUIT_RESET_SECONDS=60

# ===================================
# LLM configuration (OpenAI-compatible only)
# 必填：OPENAI_API_KEY(S) + OPENAI_MODEL
# ===================================
# 模型名称（示例：gpt-4o-mini / gpt-4o）
OPENAI_MODEL=gpt-4o-mini

# API Key（优先用 OPENAI_API_KEYS，多个用逗号分隔）
OPENAI_API_KEY=
# API Keys（多个用逗号分隔）
OPENAI_API_KEYS=

# OpenAI-compatible Base URL
# 1) 留空时默认使用 https://api.openai.com/v1/chat/completions
# 2) 支持三种写法：
#    - https://api.openai.com
#    - https://api.openai.com/v1
#    - https://api.openai.com/v1/chat/completions
OPENAI_BASE_URL=

# LLM 调用参数
# TEMPERATURE：越高越发散，默认 0.7
# MAX_TOKENS：输出上限（不同模型上限不同）
# TIMEOUT_SECONDS：请求超时秒数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SECONDS=120

# ===================================
# News (V1 default: Tavily)
# ===================================
# Tavily API Keys（多个用逗号分隔）
TAVILY_API_KEYS=
# Tavily Base URL（可选）
# TAVILY_BASE_URL= # 例如: https://tavily.ivanli.cc/api/tavily
# 新闻最大可用天数
NEWS_MAX_AGE_DAYS=3
# 新闻提供方优先级
NEWS_PROVIDER_PRIORITY=tavily

# ===================================
# Scheduler (cron-like: sec min hour day month weekday)
# ===================================
# 是否启用调度
SCHEDULE_ENABLED=false
# A 股调度 Cron
SCHEDULE_CRON_CN=0 30 15 * * 1-5
# 港股调度 Cron
SCHEDULE_CRON_HK=0 10 16 * * 1-5
# 美股调度 Cron
SCHEDULE_CRON_US=0 10 22 * * 1-5

# ===================================
# Notification (Phase 3: multi-channel)
# ===================================
# 通知渠道列表（逗号分隔）
NOTIFY_CHANNELS=feishu
# 飞书 Webhook URL
FEISHU_WEBHOOK_URL=
# 企业微信 Webhook URL
WECHAT_WEBHOOK_URL=
# Telegram Bot Token
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID
TELEGRAM_CHAT_ID=
# SMTP 主机
EMAIL_SMTP_HOST=
# SMTP 端口
EMAIL_SMTP_PORT=25
# SMTP 用户名
EMAIL_USERNAME=
# SMTP 密码
EMAIL_PASSWORD=
# 发件人地址
EMAIL_FROM=
# 收件人地址（逗号分隔）
EMAIL_TO=
# 报告模板目录
REPORT_TEMPLATES_DIR=templates
# 是否启用报告渲染
REPORT_RENDERER_ENABLED=false
# 是否启用报告完整性校验
REPORT_INTEGRITY_ENABLED=true
# 历史对比条数
REPORT_HISTORY_COMPARE_N=0
# 需要转图片的渠道列表
MARKDOWN_TO_IMAGE_CHANNELS=
# Markdown 转图最大字符数
MARKDOWN_TO_IMAGE_MAX_CHARS=15000
# Markdown 转图引擎
MD2IMG_ENGINE=imgkit
# 是否启用指标上报
METRICS_ENABLED=true

# ===================================
# Task reliability and lifecycle (Phase 4)
# ===================================
# 任务最大并发数
TASK_MAX_CONCURRENCY=2
# 任务队列最大长度（兼容项）
TASK_QUEUE_MAX_SIZE=50
# 单任务超时（秒）
TASK_TIMEOUT_SECONDS=120
# 任务去重窗口（秒，兼容项）
TASK_DEDUP_WINDOW_SECONDS=300
# 任务保留天数
RETENTION_TASK_DAYS=30
# 报告保留天数
RETENTION_REPORT_DAYS=60
# 行情保留天数
RETENTION_QUOTE_DAYS=14
# 行业趋势窗口天数
INDUSTRY_TREND_WINDOW_DAYS=5
# 行业风险 Top N
INDUSTRY_RISK_TOP_N=3
# 行业推荐权重（JSON）
INDUSTRY_RECOMMEND_WEIGHTS={"buy":1,"hold":0,"sell":-1,"score_weight":0.5}

# ===================================
# API auth (Phase 3)
# ===================================
# 是否启用 API 鉴权
API_AUTH_ENABLED=false
# 管理员 Token
API_ADMIN_TOKEN=
